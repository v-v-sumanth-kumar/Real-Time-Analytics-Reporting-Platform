# Application
APP_NAME=Analytics Platform
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Database (async SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://analytics:analytics@localhost:5432/analytics

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000

# Rate limiting (events per org per minute)
INGEST_RATE_LIMIT_PER_MINUTE=10000

# Cookie (refresh token)
COOKIE_SECURE=false
COOKIE_DOMAIN=
